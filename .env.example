# API keys - set the one(s) for the providers you use in task.json.
# The `label` and `synth` blocks each pick a provider independently.
# Copy this file to .env and fill in what you need.

# OpenAI (default for both stages)
OPENAI_API_KEY=sk-...

# Anthropic (Claude) - only if a block uses "provider": "anthropic"
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini) - only if a block uses "provider": "google"
GOOGLE_GENERATIVE_AI_API_KEY=...

# Ollama (local) - no key needed; optionally override the host
# OLLAMA_HOST=http://localhost:11434/api

# Optional defaults (task.json takes precedence):
#   LABEL_PROVIDER / LABEL_MODEL  - labeling backend (default openai / gpt-4o-mini)
#   SYNTH_PROVIDER / SYNTH_MODEL  - code-synth backend (default openai / gpt-5.4-mini)
LABEL_PROVIDER=openai
LABEL_MODEL=gpt-4o-mini
SYNTH_PROVIDER=openai
SYNTH_MODEL=gpt-5.4-mini
